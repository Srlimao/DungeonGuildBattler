{
  "name": "dungeon-guild-battler",
  "version": "0.3.0",
  "description": "Multiplayer 2D Auto-Battler Client & Server",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm --prefix src/renderer run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "build:ui": "npm --prefix src/renderer run build",
    "dist": "electron-builder",
    "build": "npm run build:ui && npm run dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Srlimao/DungeonGuildBattler.git"
  },
  "build": {
    "files": [
      "src/main/**/*",
      "src/shared/**/*",
      "src/renderer/dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "out"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Srlimao",
        "repo": "DungeonGuildBattler"
      }
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^10.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^26.15.3",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "steamworks.js": "^0.4.0"
  }
}
